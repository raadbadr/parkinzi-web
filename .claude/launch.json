{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Wrangler Dev (Cloudflare)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "pages", "dev", "./", "--port", "8788"],
      "port": 8788
    },
    {
      "name": "Static File Server (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3000"],
      "port": 3000
    }
  ]
}
